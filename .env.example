# Copy to .env.local for local dev, or set in docker-compose for the container.

# Where the SQLite database file lives. Locally this can be a relative path;
# in Docker it points at the persistent volume.
DATABASE_URL=file:./data/db/app.db

# Directory for stored raw uploaded activity files.
UPLOAD_DIR=./data/uploads

# Passcode the single admin types at /admin to manage teams & achievements.
ADMIN_PASSCODE=Test1

# Secret used to sign the admin session cookie (HMAC). Use a long random string.
SESSION_SECRET=change-me-to-a-long-random-string
